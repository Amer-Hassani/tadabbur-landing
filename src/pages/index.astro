---
import Base from '../layouts/Base.astro';
---

<Base>
  <header class="site-header">
    <div class="container">
      <a href="#" class="wordmark">تدبّر</a>
      <a href="#join" class="btn header-cta">ابدأ رحلة التدبّر</a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container">
        <span class="eyebrow">منصة تفاعلية لتفسير القرآن الكريم</span>
        <h1>أن يصل المعنى إلى <em>القلب</em> قبل العقل</h1>
        <p class="lead">
          نُعيد تقديم التفاسير الأصيلة في تجربة حديثة ومبسّطة — تفسيرٌ يناسب عمرك
          ومستواك، ويحوّل الفهم إلى عمل.
        </p>
        <a href="#join" class="btn">ابدأ رحلة التدبّر</a>
        <span class="hint">انضم لقائمة الانتظار وكن من أوائل من يجرّب الإصدار الأول</span>
      </div>
    </section>

    <!-- Interactive verse search -->
    <section class="demo">
      <div class="container">
        <div class="demo-card reveal">
          <div class="verse-picker">
            <div class="picker-field">
              <label for="surah-search">السورة</label>
              <input
                type="text"
                id="surah-search"
                placeholder="ابحث عن سورة… (مثل: البقرة)"
                autocomplete="off"
                aria-expanded="false"
                aria-controls="surah-results"
              />
              <ul id="surah-results" class="surah-results" role="listbox" hidden></ul>
            </div>
            <div class="picker-field">
              <label for="ayah-select">الآية</label>
              <select id="ayah-select" disabled>
                <option>اختر سورة أولاً</option>
              </select>
            </div>
          </div>

          <div id="verse-state">
            <p class="demo-hint">ابحث عن سورة، ثم اختر آية لعرض تفسيرها من مصادر موثوقة.</p>
          </div>

          <template id="verse-template">
            <p class="ayah" data-el="ayah-text"></p>
            <span class="ayah-ref" data-el="ayah-ref"></span>

            <div class="level-tabs" data-el="source-tabs" role="tablist" aria-label="اختر مصدر التفسير"></div>
            <div data-el="source-panels"></div>
          </template>
        </div>
      </div>
    </section>

    <!-- Value points -->
    <section id="idea">
      <div class="container">
        <div class="section-head reveal">
          <h2>من نصٍّ صعب… إلى فهمٍ يقود إلى عمل</h2>
          <p>
            كثيراً ما يبقى التفسير بعيداً عن حياتنا اليومية. تدبّر يجعل معنى الآية
            أقرب وأوضح — لتخرج من كل آية بفهمٍ وخطوة.
          </p>
        </div>
        <div class="points">
          <div class="point reveal">
            <span class="icon">🌱</span>
            <h3>معنى أقرب</h3>
            <p>نبسّط العبارة دون أن نمسّ المعنى، ليفهم كلُّ قارئ مراد الآية بيسر.</p>
          </div>
          <div class="point reveal">
            <span class="icon">🎚️</span>
            <h3>لكل مستوى</h3>
            <p>المحتوى نفسه يتكيّف مع القارئ: طفلاً كان، أو مبتدئاً، أو طالبَ علم.</p>
          </div>
          <div class="point reveal">
            <span class="icon">🧭</span>
            <h3>من الفهم إلى العمل</h3>
            <p>كل آية تنتهي بخطوة عملية صغيرة، لأن الفهم طريق العمل.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Audience tiers -->
    <section id="audience">
      <div class="container">
        <div class="section-head reveal">
          <h2>تفسير واحد… بثلاثة أبواب</h2>
          <p>اختر المستوى الذي يناسبك، ويتغيّر المحتوى معك.</p>
        </div>
        <div class="tiers">
          <div class="tier kids reveal">
            <span class="badge">للأطفال</span>
            <h3>لغة سهلة وقصص قريبة</h3>
            <p>تفسير مبسّط بلغة يفهمها الطفل، يزرع حبّ القرآن ومعانيه منذ الصغر.</p>
          </div>
          <div class="tier mid reveal">
            <span class="badge">للمستوى المتوسط</span>
            <h3>أمثلة عملية من الحياة</h3>
            <p>ربط معنى الآية بمواقف يومية حقيقية، ليتحوّل الفهم إلى سلوك وعمل.</p>
          </div>
          <div class="tier adv reveal">
            <span class="badge">للمتقدمين</span>
            <h3>تفسير معمّق مع المصادر</h3>
            <p>غوصٌ في أقوال المفسّرين ولطائف اللغة، مع إحالة واضحة إلى المصادر.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust -->
    <section class="trust">
      <div class="container">
        <div class="reveal">
          <h2>أصالةٌ في المصدر، حداثةٌ في التقديم</h2>
          <p>
            لا نبتدع تفاسير جديدة. نُعيد ترتيب وتقديم الكنوز التفسيرية الموثوقة —
            كتفسير ابن كثير والطبري والسعدي — في تجربة تفاعلية حديثة تناسب كل
            مرحلة عمرية. المصدر أصيل، والقالب جديد.
          </p>
        </div>
        <div class="trust-quote reveal">
          <p class="big">«الفهم طريق العمل»</p>
        </div>
      </div>
    </section>

    <!-- Video teaser -->
    <section id="video">
      <div class="container">
        <div class="section-head reveal">
          <h2>شاهد كيف تعمل المنصة</h2>
          <p>فيديو قصير يوضح التفاعل مع الآية وكيف يتغيّر المحتوى حسب المستوى.</p>
        </div>
        <div class="video-frame reveal">
          <div class="play-circle">▶</div>
          <p>الفيديو التعريفي قريباً — ٣٠ إلى ٤٥ ثانية</p>
        </div>
      </div>
    </section>

    <!-- Waitlist -->
    <section class="waitlist" id="join">
      <div class="container">
        <div class="waitlist-card reveal">
          <h2>كن من أوائل المتدبّرين</h2>
          <p>
            سجّل بريدك الإلكتروني لنخبرك عند إطلاق الإصدار الأول، ولتكون من أوائل
            من يجرّب المنصة.
          </p>
          <form class="waitlist-form" id="waitlist-form">
            <input
              type="email"
              name="email"
              placeholder="بريدك الإلكتروني"
              required
              aria-label="البريد الإلكتروني"
            />
            <button type="submit" class="btn">ابدأ رحلة التدبّر</button>
          </form>
          <p class="waitlist-success" id="waitlist-success" hidden>
            🌿 تمّ تسجيلك بنجاح! سنراسلك عند إطلاق الإصدار الأول بإذن الله.
          </p>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <span class="wordmark">تدبّر</span>
      <p>ليصل المعنى إلى القلب قبل العقل · © ٢٠٢٦ تدبّر</p>
      <p class="attribution">
        نصوص القرآن والتفسير مقدَّمة عبر Tafsir MCP، برعاية مركز تفسير للدراسات القرآنية (CC BY 4.0)
      </p>
    </div>
  </footer>

  <script>
    const API_BASE = 'https://tadabbur-tafsir-api.amer19hs.workers.dev';

    type Surah = { surah_no: number; name: string; revelation_type: string; ayah_count: number };
    type VerseResponse = {
      surah: number;
      ayah: number;
      text: string;
      tafsirs: { source: string; attribution: string; text: string }[];
    };

    const surahSearch = document.getElementById('surah-search') as HTMLInputElement;
    const surahResults = document.getElementById('surah-results') as HTMLUListElement;
    const ayahSelect = document.getElementById('ayah-select') as HTMLSelectElement;
    const verseState = document.getElementById('verse-state') as HTMLDivElement;
    const verseTemplate = document.getElementById('verse-template') as HTMLTemplateElement;

    let surahs: Surah[] = [];
    let selectedSurah: Surah | null = null;

    async function loadSurahs() {
      try {
        const res = await fetch(`${API_BASE}/api/surahs`);
        if (!res.ok) throw new Error('failed');
        surahs = await res.json();
      } catch {
        verseState.innerHTML = `<p class="demo-hint">تعذّر تحميل قائمة السور حالياً. حاول تحديث الصفحة بعد قليل.</p>`;
      }
    }
    loadSurahs();

    function renderSurahResults(query: string) {
      const q = query.trim();
      if (!q) {
        surahResults.hidden = true;
        surahResults.innerHTML = '';
        return;
      }
      const matches = surahs.filter((s) => s.name.includes(q) || String(s.surah_no) === q).slice(0, 8);
      surahResults.innerHTML = matches
        .map(
          (s) =>
            `<li role="option" data-surah="${s.surah_no}">
               <span>${s.name}</span>
               <span class="surah-meta">${s.revelation_type} · ${s.ayah_count} آية</span>
             </li>`
        )
        .join('');
      surahResults.hidden = matches.length === 0;
    }

    surahSearch.addEventListener('input', () => renderSurahResults(surahSearch.value));
    surahSearch.addEventListener('focus', () => renderSurahResults(surahSearch.value));
    document.addEventListener('click', (e) => {
      if (!(e.target instanceof Node)) return;
      if (!surahResults.contains(e.target) && e.target !== surahSearch) {
        surahResults.hidden = true;
      }
    });

    surahResults.addEventListener('click', (e) => {
      const li = (e.target as HTMLElement).closest('li[data-surah]') as HTMLLIElement | null;
      if (!li) return;
      const surahNo = Number(li.dataset.surah);
      selectedSurah = surahs.find((s) => s.surah_no === surahNo) ?? null;
      if (!selectedSurah) return;

      surahSearch.value = selectedSurah.name;
      surahResults.hidden = true;

      ayahSelect.disabled = false;
      ayahSelect.innerHTML = Array.from(
        { length: selectedSurah.ayah_count },
        (_, i) => `<option value="${i + 1}">آية ${i + 1}</option>`
      ).join('');
      ayahSelect.dispatchEvent(new Event('change'));
    });

    ayahSelect.addEventListener('change', () => {
      if (!selectedSurah || ayahSelect.disabled) return;
      const ayahNo = Number(ayahSelect.value);
      if (ayahNo) loadVerse(selectedSurah.surah_no, ayahNo);
    });

    async function loadVerse(surah: number, ayah: number) {
      verseState.innerHTML = `<p class="demo-hint">جارٍ التحميل…</p>`;
      try {
        const res = await fetch(`${API_BASE}/api/verse?surah=${surah}&ayah=${ayah}`);
        if (!res.ok) throw new Error('failed');
        const data: VerseResponse = await res.json();
        renderVerse(data);
      } catch {
        verseState.innerHTML = `<p class="demo-hint">تعذّر جلب الآية الآن. جرّب مرة أخرى بعد قليل.</p>`;
      }
    }

    function renderVerse(data: VerseResponse) {
      const frag = verseTemplate.content.cloneNode(true) as DocumentFragment;
      const ayahText = frag.querySelector('[data-el="ayah-text"]')!;
      const ayahRef = frag.querySelector('[data-el="ayah-ref"]')!;
      const tabs = frag.querySelector('[data-el="source-tabs"]') as HTMLDivElement;
      const panels = frag.querySelector('[data-el="source-panels"]') as HTMLDivElement;

      ayahText.textContent = `﴿ ${data.text} ﴾`;
      ayahRef.textContent = `سورة ${selectedSurah?.name ?? data.surah} — الآية ${data.ayah}`;

      data.tafsirs.forEach((t, i) => {
        const tab = document.createElement('button');
        tab.className = 'level-tab';
        tab.type = 'button';
        tab.setAttribute('role', 'tab');
        tab.setAttribute('aria-selected', String(i === 0));
        tab.setAttribute('aria-controls', `panel-${t.source}`);
        tab.textContent = t.attribution.split('،')[0];
        tabs.appendChild(tab);

        const panel = document.createElement('div');
        panel.className = 'level-panel';
        panel.id = `panel-${t.source}`;
        panel.setAttribute('role', 'tabpanel');
        panel.hidden = i !== 0;
        panel.textContent = t.text;
        panels.appendChild(panel);

        tab.addEventListener('click', () => {
          tabs.querySelectorAll('.level-tab').forEach((el) => el.setAttribute('aria-selected', 'false'));
          panels.querySelectorAll('.level-panel').forEach((el) => ((el as HTMLElement).hidden = true));
          tab.setAttribute('aria-selected', 'true');
          panel.hidden = false;
        });
      });

      verseState.innerHTML = '';
      verseState.appendChild(frag);
    }

    // Waitlist form — replace with a real endpoint (e.g. Formspree / Mailchimp) before launch
    const form = document.getElementById('waitlist-form') as HTMLFormElement | null;
    const success = document.getElementById('waitlist-success');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      form.hidden = true;
      if (success) success.hidden = false;
    });
  </script>
</Base>
