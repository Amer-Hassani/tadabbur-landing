---
import Base from '../layouts/Base.astro';
---

<Base>
  <header class="site-header">
    <div class="container">
      <a href="#" class="wordmark">تدبّر</a>
      <div class="header-actions">
        <button id="lang-toggle" class="icon-btn" type="button" aria-label="Change language">
          <span data-lang-ar>English</span>
          <span data-lang-en>العربية</span>
        </button>
        <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle theme">
          <span class="theme-icon">🌙</span>
        </button>
        <a href="#join" class="btn header-cta">
          <span data-lang-ar>ابدأ رحلة التدبّر</span>
          <span data-lang-en>Begin your journey</span>
        </a>
      </div>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero" id="hero">
      <div class="container">
        <span class="eyebrow">
          <span data-lang-ar>منصة تفاعلية لتفسير القرآن الكريم</span>
          <span data-lang-en>An interactive platform for Qur'anic tafsir</span>
        </span>
        <h1>
          <span data-lang-ar>أن يصل المعنى إلى <em>القلب</em> قبل العقل</span>
          <span data-lang-en>Let meaning reach the <em>heart</em> before the mind</span>
        </h1>
        <p class="lead">
          <span data-lang-ar>
            نُعيد تقديم التفاسير الأصيلة في تجربة حديثة ومبسّطة — تفسيرٌ يناسب عمرك
            ومستواك، ويحوّل الفهم إلى عمل.
          </span>
          <span data-lang-en>
            We present authentic tafsir in a modern, simplified experience — an
            interpretation that fits your level and turns understanding into action.
          </span>
        </p>
        <a href="#join" class="btn">
          <span data-lang-ar>ابدأ رحلة التدبّر</span>
          <span data-lang-en>Begin your journey</span>
        </a>
        <span class="hint">
          <span data-lang-ar>انضم لقائمة الانتظار وكن من أوائل من يجرّب الإصدار الأول</span>
          <span data-lang-en>Join the waitlist and be among the first to try the first release</span>
        </span>
      </div>
    </section>

    <!-- Fixed example -->
    <section class="demo">
      <div class="container">
        <div class="section-head reveal">
          <h2>
            <span data-lang-ar>هكذا يعمل تدبّر</span>
            <span data-lang-en>How Tadabbur works</span>
          </h2>
          <p>
            <span data-lang-ar>اختر مصدراً من المصادر الموثوقة لتقرأ تفسيره لهذه الآية.</span>
            <span data-lang-en>Choose a trusted source to read its tafsir of this verse.</span>
          </p>
        </div>
        <div class="demo-card reveal">
          <div id="example-state">
            <p class="demo-hint">
              <span data-lang-ar>جارٍ التحميل…</span>
              <span data-lang-en>Loading…</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Free verse search -->
    <section class="demo" id="search">
      <div class="container">
        <div class="section-head reveal">
          <h2>
            <span data-lang-ar>جرّب بنفسك</span>
            <span data-lang-en>Try it yourself</span>
          </h2>
          <p>
            <span data-lang-ar>اختر أي سورة، ثم أي آية، لتقرأ تفسيرها من المصادر نفسها.</span>
            <span data-lang-en>Pick any surah, then any verse, and read its tafsir from the same sources.</span>
          </p>
        </div>
        <div class="demo-card reveal">
          <div class="verse-picker">
            <div class="picker-field">
              <label id="surah-label">
                <span data-lang-ar>السورة</span><span data-lang-en>Surah</span>
              </label>
              <button
                type="button"
                id="surah-trigger"
                class="picker-trigger"
                aria-haspopup="listbox"
                aria-expanded="false"
                aria-controls="surah-results"
                aria-labelledby="surah-label surah-trigger"
              >
                <span class="picker-trigger-text" id="surah-trigger-text">
                  <span data-lang-ar>اختر سورة</span>
                  <span data-lang-en>Choose a surah</span>
                </span>
                <span class="picker-caret" aria-hidden="true">▾</span>
              </button>
              <ul id="surah-results" class="surah-results" role="listbox" tabindex="-1" hidden></ul>
            </div>
            <div class="picker-field">
              <label for="ayah-select">
                <span data-lang-ar>الآية</span><span data-lang-en>Verse</span>
              </label>
              <select id="ayah-select" disabled>
                <option data-lang-ar>اختر سورة أولاً</option>
                <option data-lang-en>Choose a surah first</option>
              </select>
            </div>
            <div class="picker-field" id="source-field" hidden>
              <label for="source-select">
                <span data-lang-ar>التفسير</span><span data-lang-en>Tafsir</span>
              </label>
              <select id="source-select"></select>
            </div>
          </div>

          <div id="verse-state">
            <p class="demo-hint">
              <span data-lang-ar>اختر سورة، ثم اختر آية لعرض تفسيرها من مصادر موثوقة.</span>
              <span data-lang-en>Choose a surah, then pick a verse to see its tafsir from trusted sources.</span>
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Trust -->
    <section class="trust">
      <div class="container">
        <div class="reveal">
          <h2>
            <span data-lang-ar>أصالةٌ في المصدر، حداثةٌ في التقديم</span>
            <span data-lang-en>Authentic in source, modern in presentation</span>
          </h2>
          <p>
            <span data-lang-ar>
              لا نبتدع تفاسير جديدة. نُعيد ترتيب وتقديم الكنوز التفسيرية الموثوقة —
              كتفسير ابن كثير والطبري والسعدي — في تجربة تفاعلية حديثة تناسب كل
              مرحلة عمرية. المصدر أصيل، والقالب جديد.
            </span>
            <span data-lang-en>
              We invent no new interpretations. We re-present the trusted treasures of
              tafsir — such as Ibn Kathir, Al-Tabari, and Al-Sa'di — in a modern
              interactive experience for every age. The source is authentic; the form is new.
            </span>
          </p>
        </div>
        <div class="trust-quote reveal">
          <p class="big">«الفهم طريق العمل»</p>
        </div>
      </div>
    </section>

    <!-- Video teaser -->
    <section id="video">
      <div class="container">
        <div class="section-head reveal">
          <h2>
            <span data-lang-ar>شاهد كيف تعمل المنصة</span>
            <span data-lang-en>See how the platform works</span>
          </h2>
          <p>
            <span data-lang-ar>فيديو قصير يوضح التفاعل مع الآية وكيف يتغيّر المحتوى حسب المستوى.</span>
            <span data-lang-en>A short video showing interaction with a verse and how content changes by level.</span>
          </p>
        </div>
        <div class="video-frame reveal">
          <div class="play-circle">▶</div>
          <p>
            <span data-lang-ar>الفيديو التعريفي قريباً — ٣٠ إلى ٤٥ ثانية</span>
            <span data-lang-en>Intro video coming soon — 30 to 45 seconds</span>
          </p>
        </div>
      </div>
    </section>

    <!-- Waitlist -->
    <section class="waitlist" id="join">
      <div class="container">
        <div class="waitlist-card reveal">
          <h2>
            <span data-lang-ar>كن من أوائل المتدبّرين</span>
            <span data-lang-en>Be among the first</span>
          </h2>
          <p>
            <span data-lang-ar>
              سجّل بريدك الإلكتروني لنخبرك عند إطلاق الإصدار الأول، ولتكون من أوائل
              من يجرّب المنصة.
            </span>
            <span data-lang-en>
              Enter your email and we'll let you know when the first release launches —
              and you'll be among the first to try it.
            </span>
          </p>
          <form class="waitlist-form" id="waitlist-form">
            <input
              type="email"
              name="email"
              required
              aria-label="Email"
              data-ph-ar="بريدك الإلكتروني"
              data-ph-en="Your email address"
            />
            <button type="submit" class="btn">
              <span data-lang-ar>ابدأ رحلة التدبّر</span>
              <span data-lang-en>Begin your journey</span>
            </button>
          </form>
          <p class="waitlist-note" id="waitlist-note" role="status"></p>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="container">
      <span class="wordmark">تدبّر</span>
      <p>
        <span data-lang-ar>ليصل المعنى إلى القلب قبل العقل · © ٢٠٢٦ تدبّر</span>
        <span data-lang-en>Let meaning reach the heart before the mind · © 2026 Tadabbur</span>
      </p>
      <p class="attribution">
        <span data-lang-ar>نصوص القرآن والتفسير مقدَّمة عبر Tafsir MCP، برعاية مركز تفسير للدراسات القرآنية (CC BY 4.0)</span>
        <span data-lang-en>Qur'an and tafsir texts provided via Tafsir MCP, by the Tafsir Center for Qur'anic Studies (CC BY 4.0)</span>
      </p>
    </div>
  </footer>

  <!-- ===== Mobile bottom nav ===== -->
  <nav class="bottom-nav" id="bottom-nav" aria-label="Section navigation">
    <a href="#hero" class="bottom-nav-item" data-target="hero" aria-current="page">
      <span class="bottom-nav-icon" aria-hidden="true">⌂</span>
      <span class="bottom-nav-label">
        <span data-lang-ar>الرئيسية</span>
        <span data-lang-en>Home</span>
      </span>
    </a>
    <a href="#search" class="bottom-nav-item" data-target="search">
      <span class="bottom-nav-icon" aria-hidden="true">⌕</span>
      <span class="bottom-nav-label">
        <span data-lang-ar>البحث</span>
        <span data-lang-en>Search</span>
      </span>
    </a>
    <a href="#join" class="bottom-nav-item" data-target="join">
      <span class="bottom-nav-icon" aria-hidden="true">✉</span>
      <span class="bottom-nav-label">
        <span data-lang-ar>انضم</span>
        <span data-lang-en>Join</span>
      </span>
    </a>
  </nav>

  <!-- ===== Install app banner (PWA) ===== -->
  <div
    class="install-banner"
    id="install-banner"
    role="region"
    aria-live="polite"
    aria-label="Install Tadabbur app"
    hidden
  >
    <div class="install-banner-inner">
      <span class="install-banner-icon" aria-hidden="true">تدبّر</span>
      <div class="install-banner-text">
        <span data-install-copy="default" hidden>
          <span data-lang-ar>ثبّت تطبيق تدبّر على جهازك للوصول السريع.</span>
          <span data-lang-en>Install the Tadabbur app for quick access.</span>
        </span>
        <span data-install-copy="ios" hidden>
          <span data-lang-ar>لتثبيت التطبيق: اضغط زر المشاركة ⬆︎ ثم اختر «إضافة إلى الشاشة الرئيسية».</span>
          <span data-lang-en>To install: tap Share ⬆︎, then choose "Add to Home Screen".</span>
        </span>
      </div>
      <div class="install-banner-actions">
        <button type="button" class="btn btn--gold install-banner-action" id="install-banner-action" hidden>
          <span data-lang-ar>تثبيت</span>
          <span data-lang-en>Install</span>
        </button>
        <button
          type="button"
          class="install-banner-dismiss"
          id="install-banner-dismiss"
          aria-label="Dismiss install banner"
        >
          <span aria-hidden="true">✕</span>
        </button>
      </div>
    </div>
  </div>

  <script>
    // API base is chosen at build time: staging builds set PUBLIC_API_BASE to the
    // staging Worker; production defaults to the production Worker.
    const API_BASE =
      import.meta.env.PUBLIC_API_BASE || 'https://tadabbur-tafsir-api.amer19hs.workers.dev';
    const EXAMPLE_SURAH = 94;
    const EXAMPLE_AYAH = 6;

    type Surah = { surah_no: number; name: string; revelation_type: string; ayah_count: number };
    type Tafsir = { source: string; attribution: string; text: string };
    type VerseResponse = { surah: number; ayah: number; text: string; tafsirs: Tafsir[] };

    const root = document.documentElement;

    // --- Language + theme -------------------------------------------------

    const T = {
      ar: {
        ayahWord: 'آية',
        loading: 'جارٍ التحميل…',
        exampleErr: 'تعذّر تحميل المثال حالياً. حاول تحديث الصفحة بعد قليل.',
        surahErr: 'تعذّر تحميل قائمة السور حالياً. حاول تحديث الصفحة بعد قليل.',
        verseErr: 'تعذّر جلب الآية الآن. جرّب مرة أخرى بعد قليل.',
        surahLabel: (n: string) => `سورة ${n}`,
        sending: 'جارٍ التسجيل…',
        subOk: '🌿 تمّ تسجيلك بنجاح! أرسلنا لك رسالة ترحيب — تحقّق من بريدك، وإن لم تجدها فراجع مجلّد الرسائل غير المرغوب فيها (Spam).',
        subErr: 'تعذّر التسجيل الآن. تأكد من بريدك وحاول مرة أخرى.',
        badEmail: 'من فضلك أدخل بريداً إلكترونياً صحيحاً.',
      },
      en: {
        ayahWord: 'Verse',
        loading: 'Loading…',
        exampleErr: 'Could not load the example right now. Please refresh in a moment.',
        surahErr: 'Could not load the surah list right now. Please refresh in a moment.',
        verseErr: 'Could not fetch the verse right now. Please try again shortly.',
        surahLabel: (n: string) => `Surah ${n}`,
        sending: 'Signing you up…',
        subOk: '🌿 You are on the list! We sent you a welcome note — check your inbox, and if it is not there, please check your Spam / Junk folder.',
        subErr: 'Could not sign you up right now. Check your email and try again.',
        badEmail: 'Please enter a valid email address.',
      },
    };

    let lang: 'ar' | 'en' = (localStorage.getItem('tadabbur-lang') as 'ar' | 'en') || 'ar';
    let theme: 'light' | 'dark' = (localStorage.getItem('tadabbur-theme') as 'light' | 'dark') || 'light';

    function applyLang() {
      root.setAttribute('lang', lang);
      root.setAttribute('dir', lang === 'ar' ? 'rtl' : 'ltr');
      // Placeholders (can't be done with CSS)
      document.querySelectorAll<HTMLElement>('[data-ph-ar]').forEach((el) => {
        (el as HTMLInputElement).placeholder = el.dataset[lang === 'ar' ? 'phAr' : 'phEn'] || '';
      });
      // Re-render current dynamic content in the new language
      if (lastExample) renderVerseInto(exampleState, lastExample, 'الشرح', 'Ash-Sharh', { showTabs: true });
      if (currentVerse && selectedSurah) {
        renderVerseInto(verseState, currentVerse, selectedSurah.name, selectedSurah.name, { showTabs: false });
        applySourceSelection();
      }
    }

    function applyTheme() {
      root.setAttribute('data-theme', theme);
      const icon = document.querySelector('.theme-icon');
      if (icon) icon.textContent = theme === 'dark' ? '☀️' : '🌙';
      // Keep the mobile browser chrome / status bar in sync with the active theme.
      const themeMeta = document.getElementById('theme-color-meta');
      if (themeMeta) themeMeta.setAttribute('content', theme === 'dark' ? '#4fb488' : '#1f6f52');
    }

    document.getElementById('lang-toggle')!.addEventListener('click', () => {
      lang = lang === 'ar' ? 'en' : 'ar';
      localStorage.setItem('tadabbur-lang', lang);
      applyLang();
    });

    document.getElementById('theme-toggle')!.addEventListener('click', () => {
      theme = theme === 'light' ? 'dark' : 'light';
      localStorage.setItem('tadabbur-theme', theme);
      applyTheme();
    });

    applyTheme();

    // --- Verse rendering (shared) -----------------------------------------

    function renderVerseInto(
      container: HTMLElement,
      data: VerseResponse,
      surahNameAr: string,
      surahNameEn: string,
      options: { showTabs: boolean }
    ) {
      container.innerHTML = '';
      const t = T[lang];

      const ayahText = document.createElement('p');
      ayahText.className = 'ayah';
      ayahText.textContent = `﴿ ${data.text} ﴾`;

      const ayahRef = document.createElement('span');
      ayahRef.className = 'ayah-ref';
      const name = lang === 'ar' ? surahNameAr : surahNameEn;
      ayahRef.textContent = `${t.surahLabel(name)} — ${t.ayahWord} ${data.ayah}`;

      const panels = document.createElement('div');
      const tabs = options.showTabs ? document.createElement('div') : null;
      if (tabs) {
        tabs.className = 'level-tabs';
        tabs.setAttribute('role', 'tablist');
      }

      data.tafsirs.forEach((tf, i) => {
        const panelId = `panel-${tf.source}-${data.surah}-${data.ayah}`;

        const panel = document.createElement('div');
        panel.className = 'level-panel';
        panel.id = panelId;
        panel.setAttribute('role', 'tabpanel');
        panel.hidden = i !== 0;
        panel.textContent = tf.text;
        panels.appendChild(panel);

        if (tabs) {
          const tab = document.createElement('button');
          tab.className = 'level-tab';
          tab.type = 'button';
          tab.setAttribute('role', 'tab');
          tab.setAttribute('aria-selected', String(i === 0));
          tab.setAttribute('aria-controls', panelId);
          tab.textContent = tf.attribution.split('،')[0];
          tabs.appendChild(tab);
          tab.addEventListener('click', () => {
            tabs.querySelectorAll('.level-tab').forEach((el) => el.setAttribute('aria-selected', 'false'));
            panels.querySelectorAll('.level-panel').forEach((el) => ((el as HTMLElement).hidden = true));
            tab.setAttribute('aria-selected', 'true');
            panel.hidden = false;
          });
        }
      });

      container.append(ayahText, ayahRef, ...(tabs ? [tabs] : []), panels);
    }

    // --- Fixed example section --------------------------------------------

    const exampleState = document.getElementById('example-state') as HTMLDivElement;
    let lastExample: VerseResponse | null = null;

    async function loadExample() {
      try {
        const res = await fetch(`${API_BASE}/api/verse?surah=${EXAMPLE_SURAH}&ayah=${EXAMPLE_AYAH}`);
        if (!res.ok) throw new Error('failed');
        lastExample = await res.json();
        renderVerseInto(exampleState, lastExample!, 'الشرح', 'Ash-Sharh', { showTabs: true });
      } catch {
        exampleState.innerHTML = `<p class="demo-hint">${T[lang].exampleErr}</p>`;
      }
    }
    loadExample();

    // --- Verse picker (choose-only, no typing) ----------------------------

    const surahTrigger = document.getElementById('surah-trigger') as HTMLButtonElement;
    const surahTriggerText = document.getElementById('surah-trigger-text') as HTMLSpanElement;
    const surahResults = document.getElementById('surah-results') as HTMLUListElement;
    const ayahSelect = document.getElementById('ayah-select') as HTMLSelectElement;
    const sourceField = document.getElementById('source-field') as HTMLDivElement;
    const sourceSelect = document.getElementById('source-select') as HTMLSelectElement;
    const verseState = document.getElementById('verse-state') as HTMLDivElement;

    let surahs: Surah[] = [];
    let selectedSurah: Surah | null = null;
    let currentVerse: VerseResponse | null = null;
    let preferredSource: string | null = null;

    let surahsLoading = false;

    // The upstream tafsir server occasionally returns a transient 502. A single
    // failed load would leave the surah picker permanently empty, so retry a few
    // times with backoff before giving up, and let the user re-trigger by tapping.
    async function loadSurahs(attempt = 0) {
      if (surahsLoading || surahs.length) return;
      surahsLoading = true;
      const MAX_ATTEMPTS = 4;
      try {
        const res = await fetch(`${API_BASE}/api/surahs`);
        if (!res.ok) throw new Error('failed');
        const data = await res.json();
        if (!Array.isArray(data) || !data.length) throw new Error('empty');
        surahs = data;
        renderSurahList();
        // If the list arrived while the menu is open, reveal it now.
        if (surahTrigger.getAttribute('aria-expanded') === 'true') openSurahList();
      } catch {
        if (attempt < MAX_ATTEMPTS - 1) {
          surahsLoading = false;
          setTimeout(() => loadSurahs(attempt + 1), 800 * (attempt + 1));
          return;
        }
        verseState.innerHTML = `<p class="demo-hint">${T[lang].surahErr}</p>`;
      } finally {
        surahsLoading = false;
      }
    }
    loadSurahs();

    // Render ALL 114 surahs — no slicing, no filtering. Pure selection list.
    function renderSurahList() {
      surahResults.innerHTML = surahs
        .map(
          (s) =>
            `<li role="option" data-surah="${s.surah_no}" aria-selected="${
              selectedSurah?.surah_no === s.surah_no
            }">
               <span>${s.surah_no}. ${s.name}</span>
               <span class="surah-meta">${s.ayah_count}</span>
             </li>`
        )
        .join('');
    }

    function openSurahList() {
      // If the list hasn't loaded yet (or a transient error left it empty),
      // kick off another attempt so opening can recover instead of showing nothing.
      if (!surahs.length) {
        loadSurahs();
        return;
      }
      surahResults.hidden = false;
      surahTrigger.setAttribute('aria-expanded', 'true');
      // Scroll the currently-selected surah into view when reopening.
      const active = surahResults.querySelector('li[aria-selected="true"]') as HTMLElement | null;
      if (active) active.scrollIntoView({ block: 'nearest' });
    }

    function closeSurahList() {
      surahResults.hidden = true;
      surahTrigger.setAttribute('aria-expanded', 'false');
    }

    surahTrigger.addEventListener('click', () => {
      if (surahResults.hidden) openSurahList();
      else closeSurahList();
    });

    document.addEventListener('click', (e) => {
      if (!(e.target instanceof Node)) return;
      if (!surahResults.contains(e.target) && e.target !== surahTrigger && !surahTrigger.contains(e.target)) {
        closeSurahList();
      }
    });

    // Close on Escape for keyboard users.
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !surahResults.hidden) {
        closeSurahList();
        surahTrigger.focus();
      }
    });

    surahResults.addEventListener('click', (e) => {
      const li = (e.target as HTMLElement).closest('li[data-surah]') as HTMLLIElement | null;
      if (!li) return;
      const surahNo = Number(li.dataset.surah);
      selectedSurah = surahs.find((s) => s.surah_no === surahNo) ?? null;
      if (!selectedSurah) return;

      // Reflect the choice on the trigger button (both languages) and close.
      surahTriggerText.textContent = `${selectedSurah.surah_no}. ${selectedSurah.name}`;
      surahTriggerText.removeAttribute('data-picked-fallback');
      renderSurahList(); // refresh aria-selected highlight
      closeSurahList();
      surahTrigger.focus();

      ayahSelect.disabled = false;
      const word = T[lang].ayahWord;
      ayahSelect.innerHTML = Array.from(
        { length: selectedSurah.ayah_count },
        (_, i) => `<option value="${i + 1}">${word} ${i + 1}</option>`
      ).join('');
      ayahSelect.dispatchEvent(new Event('change'));
    });

    ayahSelect.addEventListener('change', () => {
      if (!selectedSurah || ayahSelect.disabled) return;
      const ayahNo = Number(ayahSelect.value);
      if (ayahNo) loadVerse(selectedSurah.surah_no, ayahNo);
    });

    function showSourcePanel(source: string) {
      const panel = verseState.querySelector(`[id^="panel-${source}-"]`) as HTMLElement | null;
      verseState.querySelectorAll('.level-panel').forEach((el) => ((el as HTMLElement).hidden = true));
      if (panel) panel.hidden = false;
    }

    function applySourceSelection() {
      if (!currentVerse) return;
      const activeSource =
        preferredSource && currentVerse.tafsirs.some((t) => t.source === preferredSource)
          ? preferredSource
          : currentVerse.tafsirs[0]?.source;
      sourceSelect.innerHTML = currentVerse.tafsirs
        .map(
          (t) =>
            `<option value="${t.source}"${t.source === activeSource ? ' selected' : ''}>${t.attribution.split('،')[0]}</option>`
        )
        .join('');
      sourceField.hidden = false;
      if (activeSource) showSourcePanel(activeSource);
    }

    sourceSelect.addEventListener('change', () => {
      if (!currentVerse) return;
      preferredSource = sourceSelect.value;
      showSourcePanel(sourceSelect.value);
    });

    async function loadVerse(surah: number, ayah: number) {
      sourceField.hidden = true;
      verseState.innerHTML = `<p class="demo-hint">${T[lang].loading}</p>`;
      try {
        const res = await fetch(`${API_BASE}/api/verse?surah=${surah}&ayah=${ayah}`);
        if (!res.ok) throw new Error('failed');
        currentVerse = await res.json();
        const name = selectedSurah?.name ?? String(surah);
        renderVerseInto(verseState, currentVerse!, name, name, { showTabs: false });
        applySourceSelection();
      } catch {
        verseState.innerHTML = `<p class="demo-hint">${T[lang].verseErr}</p>`;
      }
    }

    // --- Waitlist form -----------------------------------------------------

    const form = document.getElementById('waitlist-form') as HTMLFormElement;
    const note = document.getElementById('waitlist-note') as HTMLParagraphElement;
    const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const email = (form.elements.namedItem('email') as HTMLInputElement).value.trim();
      note.classList.remove('error');
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        note.textContent = T[lang].badEmail;
        note.classList.add('error');
        return;
      }
      submitBtn.disabled = true;
      note.textContent = T[lang].sending;
      try {
        const res = await fetch(`${API_BASE}/api/subscribe`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, lang }),
        });
        if (!res.ok) throw new Error('failed');
        form.reset();
        note.textContent = T[lang].subOk;
      } catch {
        note.textContent = T[lang].subErr;
        note.classList.add('error');
      } finally {
        submitBtn.disabled = false;
      }
    });

    // --- Install banner (PWA prompt) --------------------------------------

    const INSTALL_DISMISS_KEY = 'tadabbur-install-dismissed';
    const INSTALL_DONE_KEY = 'tadabbur-install-completed';
    const DISMISS_DAYS = 14;

    const installBanner = document.getElementById('install-banner') as HTMLDivElement | null;
    const installAction = document.getElementById('install-banner-action') as HTMLButtonElement | null;
    const installDismiss = document.getElementById('install-banner-dismiss') as HTMLButtonElement | null;

    if (installBanner && installAction && installDismiss) {
      let deferredInstallPrompt: any = null;

      const isStandalone = () =>
        window.matchMedia('(display-mode: standalone)').matches ||
        (navigator as any).standalone === true;

      const isDismissedRecently = () => {
        try {
          const raw = localStorage.getItem(INSTALL_DISMISS_KEY);
          if (!raw) return false;
          const at = Number(raw);
          if (Number.isNaN(at)) return false;
          return (Date.now() - at) / (1000 * 60 * 60 * 24) < DISMISS_DAYS;
        } catch {
          return false;
        }
      };

      const isAlreadyInstalled = () => {
        try {
          return localStorage.getItem(INSTALL_DONE_KEY) === '1';
        } catch {
          return false;
        }
      };

      // Any iOS browser (all use WebKit, none fire beforeinstallprompt).
      // Modern iPadOS reports as "Macintosh" with touch, so check for that too.
      const isIos = () => {
        const ua = navigator.userAgent;
        const iDevice = /iPad|iPhone|iPod/.test(ua) && !(window as any).MSStream;
        const iPadOS = ua.includes('Macintosh') && navigator.maxTouchPoints > 1;
        return (iDevice || iPadOS) && !isStandalone();
      };

      const rememberDismissal = () => {
        try {
          localStorage.setItem(INSTALL_DISMISS_KEY, String(Date.now()));
        } catch {}
      };
      const rememberInstalled = () => {
        try {
          localStorage.setItem(INSTALL_DONE_KEY, '1');
        } catch {}
      };

      function showBanner(mode: 'default' | 'ios') {
        if (isStandalone() || isAlreadyInstalled() || isDismissedRecently()) return;
        installBanner!.querySelectorAll<HTMLElement>('[data-install-copy]').forEach((el) => {
          el.hidden = el.dataset.installCopy !== mode;
        });
        installAction!.hidden = mode === 'ios';
        installBanner!.hidden = false;
        requestAnimationFrame(() => installBanner!.classList.add('is-visible'));
      }

      function hideBanner() {
        installBanner!.classList.remove('is-visible');
        // If there's no transition (e.g. reduced motion), transitionend may never
        // fire, so also fall back to a timeout that matches the CSS duration.
        let done = false;
        const finish = () => {
          if (done) return;
          done = true;
          installBanner!.hidden = true;
        };
        installBanner!.addEventListener('transitionend', finish, { once: true });
        window.setTimeout(finish, 500);
      }

      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        deferredInstallPrompt = e;
        showBanner('default');
      });

      installAction.addEventListener('click', async () => {
        if (!deferredInstallPrompt) {
          hideBanner();
          return;
        }
        deferredInstallPrompt.prompt();
        try {
          await deferredInstallPrompt.userChoice;
        } catch {}
        deferredInstallPrompt = null;
        hideBanner();
      });

      installDismiss.addEventListener('click', () => {
        rememberDismissal();
        hideBanner();
      });

      window.addEventListener('appinstalled', () => {
        rememberInstalled();
        hideBanner();
      });

      // iOS never fires beforeinstallprompt — show manual instructions instead.
      if (isIos()) showBanner('ios');
    }

    // Initial language application (placeholders, direction already set inline)
    applyLang();
  </script>
</Base>
